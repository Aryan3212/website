---
import HeaderLink from '@/components/HeaderLink'
import MenuIcon from './icons/MenuIcon.astro'
import Search from '@/components/Search'
import TagIcon from './icons/TagIcon.astro'
import ToggleTheme from './ToggleTheme.astro'
import Contacts from '@/components/Contacts'
---

<header class='relative flex h-12 items-center justify-between gap-4 font-semibold'>
	<div class='flex items-center gap-4'>
		<a
			href='/'
			class='text-sm font-black tracking-[0.22em] underline underline-offset-4 decoration-2'
		>
			[HOME]
		</a>
		<a
			href='/blog'
			class='text-sm font-black tracking-[0.22em] underline underline-offset-4 decoration-2'
		>
			[BLOG]
		</a>
	</div>

	<div class='hidden md:flex items-center gap-6'>
		<div class='flex items-center gap-3'>
			<a
				href='/tags'
				class='text-sm font-black tracking-[0.16em] underline underline-offset-4 decoration-2'
			>
				[TAGS]
			</a>
			<Search />
			<ToggleTheme />
		</div>

		<div class='flex items-center gap-4 text-sm font-normal'>
			<span class='font-mono text-opacity-80'>rahman.aryan07@gmail.com</span>
			<span class='text-opacity-40'>·</span>
			<a
				href='https://github.com/aryan3212'
				target='_blank'
				rel='noopener noreferrer'
				class='underline underline-offset-4 text-opacity-80 hover:text-opacity-100'
			>
				GitHub
			</a>
			<a
				href='https://www.linkedin.com/in/aryanrahman3212/'
				target='_blank'
				rel='noopener noreferrer'
				class='underline underline-offset-4 text-opacity-80 hover:text-opacity-100'
			>
				LinkedIn
			</a>
			<a
				href='https://x.com/aryantwitting'
				target='_blank'
				rel='noopener noreferrer'
				class='underline underline-offset-4 text-opacity-80 hover:text-opacity-100'
			>
				X
			</a>
		</div>
	</div>

	<div class='flex items-center gap-3 md:hidden' transition:persist='navbar'>
		<Search />
		<ToggleTheme />
		<button id='astro-header-drawer-button' type='button'>
			<MenuIcon />
			<span class='sr-only'>Show Menu</span>
		</button>
	</div>

	<div
		id='astro-header-drawer'
		class='shadow rounded-l-lg bg-white dark:bg-[#1b1d23] absolute transition-transform duration-300 ease-in translate-x-96 top-12 -right-5 p-2 pt-6 pb-4 w-[280px] z-50 md:hidden'
	>
		<nav class='flex h-full flex-col justify-between gap-10 text-left'>
			<div class='border-b border-gray-200 pb-4 dark:border-gray-700'>
				<a
					href='/tags'
					class='text-sm font-black tracking-[0.16em] underline underline-offset-4 decoration-2'
				>
					[TAGS]
				</a>
			</div>
			<Contacts />
		</nav>
	</div>
</header>

<script>
	document.addEventListener('click', (event) => {
		const menu = document.getElementById('astro-header-drawer')
		const menuButton = document.getElementById('astro-header-drawer-button')
		const isClickInside =
			menu?.contains(event.target as HTMLDivElement) ||
			menuButton?.contains(event.target as HTMLButtonElement)

		if (isClickInside) {
			menu?.classList.toggle('translate-x-96')
		} else {
			menu?.classList.add('translate-x-96')
		}
	})
</script>
