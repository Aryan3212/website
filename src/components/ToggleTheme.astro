---
import SunIcon from '@/components/icons/SunIcon'
import MoonIcon from '@/components/icons/MoonIcon'
---

<theme-toggle class='inline-flex'>
	<button
		data-theme-toggle-button
		type='button'
		class='inline-flex h-8 w-8 items-center justify-center rounded border border-gray-300 text-gray-700 transition-colors hover:bg-gray-100 dark:border-gray-600 dark:text-gray-100 dark:hover:bg-gray-800'
		aria-label='Toggle Theme'
		aria-pressed='false'
	>
		<span data-theme-icon='sun' class='hidden' aria-hidden='true'>
			<SunIcon />
		</span>
		<span data-theme-icon='moon' aria-hidden='true'>
			<MoonIcon />
		</span>
	</button>
</theme-toggle>

<script is:inline>
	function initThemeToggle() {
		const roots = Array.from(document.querySelectorAll('theme-toggle'))
		roots.forEach((root) => {
			if (!(root instanceof HTMLElement)) return

			const button = root.querySelector('[data-theme-toggle-button]')
			const sunIcon = root.querySelector('[data-theme-icon="sun"]')
			const moonIcon = root.querySelector('[data-theme-icon="moon"]')
			if (!(button instanceof HTMLButtonElement) || !sunIcon || !moonIcon) return

			const syncButtonState = () => {
				const isDark = document.documentElement.classList.contains('dark')
				button.setAttribute('aria-pressed', String(isDark))
				sunIcon.classList.toggle('hidden', !isDark)
				moonIcon.classList.toggle('hidden', isDark)
			}

			if (button.dataset.bound !== 'true') {
				button.dataset.bound = 'true'
				button.addEventListener('click', () => {
					const isDark = document.documentElement.classList.contains('dark')
					const nextTheme = isDark ? 'light' : 'dark'
					document.dispatchEvent(new CustomEvent('theme-change', { detail: { theme: nextTheme } }))
					syncButtonState()
				})
			}

			syncButtonState()
		})
	}

	initThemeToggle()
	if (!window.__themeToggleListenersBound) {
		document.addEventListener('astro:after-swap', initThemeToggle)
		document.addEventListener('theme-change', initThemeToggle)
		window.__themeToggleListenersBound = true
	}
</script>
