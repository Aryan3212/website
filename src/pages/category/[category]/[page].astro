---
import BaseLayout from '@/layouts/BaseLayout'
import StoryPostList from '@/components/StoryPostList'
import ListCategories from '@/components/ListCategories'
import TitlePage from '@/components/TitlePage'
import { sluglify, unsluglify, getCategories, filterPostsByCategory } from '@/utils'
import { siteConfig } from '@/data/site.config'
import Pagination from '@/components/Pagination'

export async function getStaticPaths({ paginate }: any) {
	const categories = await getCategories()

	const paths = []
	for (const category of categories as string[]) {
		const unsluglifyNameCategory = unsluglify(category.toLowerCase())
		const filteredPosts = await filterPostsByCategory(unsluglifyNameCategory)

		paths.push(
			...paginate(filteredPosts, {
				params: {
					category: sluglify(category.toLowerCase())
				},
				pageSize: siteConfig.paginationSize
			})
		)
	}

	return paths
}
const params = Astro.params
const { page } = Astro.props

const unsluglifyNameCategory = unsluglify(params.category!.toLowerCase())
const posts = page.data
const normalizedCategory = params.category!.toLowerCase()

const isPortfolioCategory = normalizedCategory === 'portfolio'
const isResearchCategory = normalizedCategory === 'research'
const isFirstCategoryPage = page.currentPage === 1
---

<BaseLayout title={params.category}>
	<TitlePage title={unsluglifyNameCategory} />
	{
		isPortfolioCategory && isFirstCategoryPage && (
			<section class='mt-3'>
				<p class='max-w-3xl text-base text-gray-700 dark:text-gray-200'>
					A curated portfolio story of software work across startup and enterprise systems, with
					demos and proof inside each post.
				</p>
			</section>
		)
	}
	{
		isResearchCategory && isFirstCategoryPage && (
			<section class='mt-3'>
				<p class='max-w-3xl text-base text-gray-700 dark:text-gray-200'>
					A chronological set of deep learning research writings focused on experiments, evaluation,
					and iteration.
				</p>
			</section>
		)
	}
	<ListCategories activeCategory={params.category} />
	{
		isPortfolioCategory ? (
			<StoryPostList
				posts={posts}
				ctaLabel='Read'
				showCategory={false}
				emptyMessage='No case studies on this page.'
				preserveOrder={true}
			/>
		) : isResearchCategory ? (
			<StoryPostList
				posts={posts}
				ctaLabel='Read'
				showCategory={false}
				emptyMessage='Research notes are coming soon.'
			/>
		) : (
			<StoryPostList
				posts={posts}
				ctaLabel='Read'
				showCategory={false}
				emptyMessage='No posts on this page.'
			/>
		)
	}
	<Pagination page={page} />
</BaseLayout>
