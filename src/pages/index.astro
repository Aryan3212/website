---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'
import BaseLayout from '@/layouts/BaseLayout'
import StoryPostList from '@/components/StoryPostList'
import { filterPostsByCategory } from '@/utils'
import profileImage from '../content/blog/aryan-head.jpg'
import customUrlArchitectureImage from '../content/blog/portfolio/custom-url.png'
import gozayaanSeoChartImage from '../content/blog/portfolio/gozayaan-seo-after-graph.png'
import gozayaanSeoScreenshotImage from '../content/blog/portfolio/gozayaan-seo.png'

type ProjectProofImage = {
	src: ImageMetadata
	alt: string
	href?: string
	external?: boolean
}

type ProjectProofVideo = {
	src: string
	title: string
}

type ExperienceProject = {
	name: string
	highlight: string
	href?: string
	external?: boolean
	linkLabel?: string
	images?: ProjectProofImage[]
	video?: ProjectProofVideo
}

type ExperienceItem = {
	period: string
	role: string
	org: string
	highlight: string
	projects: ExperienceProject[]
}

const softwareCaseStudies = (await filterPostsByCategory('portfolio'))
	.filter((post) => !['portfolio/intro', 'portfolio/about-me'].includes(post.slug))
	.slice(0, 8)

const SHOTERO_LEAN_CANVAS_DEMO_URL = 'https://monhary-canvas.netlify.app/'
const SHOTERO_LEAN_CANVAS_DEMO_VIDEO_URL =
	'https://res.cloudinary.com/dwz8ueclf/video/upload/f_mp4,vc_h264,q_auto:good,ac_none/v1771860809/aryanrahman.dev/_monhary-canvas_roopds.mp4'

const softwareExperience: ExperienceItem[] = [
	{
		period: 'May 2024 - Aug 2025',
		role: 'Software Engineer I (Full Stack)',
		org: 'Optimizely',
		highlight:
			'Shipped multiple product features including custom URLs, calendar integration, secure asset sharing, and data reporting; resolved SLA-bound production issues saving ~$10,000 each on infrastructure handling ~1M requests/day.',
		projects: [
			{
				name: 'Custom URL Feature',
				highlight: 'Edge resolver with validation guardrails, monitoring, and safe rollout.',
				href: '/post/portfolio/optimizely-custom-url/',
				linkLabel: 'Read More',
				images: [
					{
						src: customUrlArchitectureImage,
						alt: 'Custom URL architecture diagram'
					}
				]
			}
		]
	},
	{
		period: 'Dec 2022 - Mar 2024',
		role: 'Software Engineer II (Frontend)',
		org: 'GoZayaan',
		highlight:
			'Shipped core frontend features and built in-house SEO web page builder that scaled organic traffic from 33k to 116k/month (~3.5x); contributed to Vue 2 to Nuxt 2 migration and mentored new teammates.',
		projects: [
			{
				name: 'SEO Content Builder',
				highlight:
					'Internal website builder that accelerated SEO page generation and ranking growth.',
				href: '/post/portfolio/gozayaan-seo-builder/',
				linkLabel: 'Read More',
				images: [
					{
						src: gozayaanSeoChartImage,
						alt: 'SEO traffic growth chart for GoZayaan'
					},
					{
						src: gozayaanSeoScreenshotImage,
						alt: 'GoZayaan SEO content builder website screenshot',
						href: 'https://gozayaan.com/route/saint-martin-ship',
						external: true
					}
				]
			}
		]
	},
	{
		period: 'Sep 2021 - Aug 2022',
		role: 'Software Engineer',
		org: 'Shotero + YY Design Studio',
		highlight:
			'Built backend features with Koa.js, PostgreSQL, and Sqitch; deployed web landing pages with YY Design Studio generating $2,000+ in client revenue.',
		projects: [
			{
				name: 'Lean Model Canvas Generator',
				highlight:
					'Interactive startup-planning generator built as a practical product experiment.',
				href: SHOTERO_LEAN_CANVAS_DEMO_URL,
				linkLabel: 'Visit App',
				video: {
					src: SHOTERO_LEAN_CANVAS_DEMO_VIDEO_URL,
					title: 'Lean Model Canvas generator web demo'
				}
			}
		]
	}
]
---

<BaseLayout title='Home'>
	<section class='mt-4 max-w-3xl mx-auto'>
		<div class='mb-6 flex items-center gap-4'>
			<Image
				src={profileImage}
				width={96}
				height={96}
				alt='Portrait of Aryan Rahman'
				class='h-20 w-20 rounded-full object-cover'
			/>
			<h1 class='text-2xl font-bold tracking-[0.14em] md:text-3xl'>ARYAN RAHMAN</h1>
		</div>

		<p class='mt-4 text-sm leading-6 text-gray-700 dark:text-gray-200'>
			Product engineer, backend-leaning. ~4 years shipping features end-to-end at Optimizely
			(enterprise SaaS, Fortune 500 clients) and GoZayaan (Bangladesh's largest OTA). I write about
			tradeoffs I've hit in production.
		</p>

		<div class='mt-4 flex flex-wrap gap-3 text-sm font-semibold'>
			<a
				href='/resume/aryan-rahman-resume-2026.pdf'
				target='_blank'
				rel='noopener noreferrer'
				class='underline'
			>
				[🔗 Software Engineering Resume]
			</a>
		</div>

		<section class='mt-8'>
			<section class='mt-8'>
				<h2
					class='text-xs font-semibold uppercase tracking-[0.22em] text-gray-600 dark:text-gray-400'
				>
					Experience
				</h2>
				<ol class='mt-4 space-y-7'>
					{
						softwareExperience.map((item) => (
							<li class='border-b border-gray-200 pb-7 last:border-b-0 dark:border-gray-700'>
								<p class='text-xs text-gray-600 dark:text-gray-300'>{item.period}</p>
								<h3 class='mt-1 text-lg font-semibold'>{item.role}</h3>
								<p class='mt-1 text-sm text-gray-700 dark:text-gray-200'>{item.org}</p>
								<ul class='mt-2 list-disc pl-5 text-sm leading-6 text-gray-700 dark:text-gray-200'>
									<li>{item.highlight}</li>
								</ul>

								{item.projects.length > 0 && (
									<div class='mt-3'>
										<p class='text-xs uppercase tracking-[0.18em] text-gray-500 dark:text-gray-400'>
											Projects
										</p>
										<ul class='mt-2 space-y-2 text-sm leading-6 text-gray-700 dark:text-gray-200'>
											{item.projects.map((project) => (
												<li class='space-y-3'>
													{project.images && project.images.length > 0 && (
														<div class='grid gap-2 sm:grid-cols-2'>
															{project.images.map((proofImage) =>
																proofImage.href ? (
																	<a
																		href={proofImage.href}
																		target={proofImage.external ? '_blank' : undefined}
																		rel={proofImage.external ? 'noopener noreferrer' : undefined}
																		aria-label={`Open live page for ${proofImage.alt}`}
																		class='group block focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-500'
																	>
																		<Image
																			src={proofImage.src}
																			width={560}
																			height={320}
																			alt={proofImage.alt}
																			class='h-[250px] w-full cursor-pointer object-cover transition-opacity group-hover:opacity-90'
																		/>
																		<span class='mt-1 inline-block text-xs font-semibold underline underline-offset-4'>
																			[Open Live Page ↗]
																		</span>
																	</a>
																) : (
																	<Image
																		src={proofImage.src}
																		width={560}
																		height={320}
																		alt={proofImage.alt}
																		class='h-[250px] w-full object-cover'
																	/>
																)
															)}
														</div>
													)}
													{project.video && (
														<video
															controls
															playsinline
															preload='metadata'
															class='h-auto w-full max-w-[560px]'
															title={project.video.title}
														>
															<source src={project.video.src} />
														</video>
													)}
													<p class='flex flex-wrap items-baseline gap-2'>
														<span class='font-semibold'>{project.name}:</span>
														<span>{project.highlight}</span>
														{project.href ? (
															<a
																href={project.href}
																target={project.external ? '_blank' : undefined}
																rel={project.external ? 'noopener noreferrer' : undefined}
																class='font-semibold hover:underline'
															>
																[{project.linkLabel ?? 'Read'}]
															</a>
														) : (
															<span class='text-xs text-gray-500 dark:text-gray-400'>
																[{project.linkLabel ?? 'Add Link'}]
															</span>
														)}
													</p>
												</li>
											))}
										</ul>
									</div>
								)}
							</li>
						))
					}
				</ol>
				<p class='mt-4 text-sm text-gray-600 dark:text-gray-300'>
					For more details, go to
					<a class='underline' href='/post/portfolio/about-me/'> A Summary of My Work till 2025</a>.
				</p>
			</section>

			<section class='mt-10'>
				<h2
					class='text-xs font-semibold uppercase tracking-[0.22em] text-gray-600 dark:text-gray-400'
				>
					Case Studies
				</h2>
				<StoryPostList
					posts={softwareCaseStudies}
					ctaLabel='Read'
					showCategory={false}
					emptyMessage='No case studies yet.'
				/>
			</section>
		</section>
	</section>
</BaseLayout>
